{
  "name": "skillkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Build, test, lint, and benchmark Agent Skills for 27+ AI coding tools",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint --workspaces --if-present",
    "lint:self": "tsx packages/cli/src/index.ts lint examples/",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --build --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skillkit/skillkit"
  },
  "keywords": [
    "agent-skills",
    "claude-code",
    "codex",
    "gemini-cli",
    "cursor",
    "ai-coding",
    "skill-testing",
    "skill-linting",
    "developer-tools"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
