{
  "name": "skillkit",
  "version": "0.1.0",
  "private": true,
  "description": "Build, test, lint, and benchmark Agent Skills for 27+ AI coding tools",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "typecheck": "tsc --build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skillkit/skillkit"
  },
  "keywords": [
    "agent-skills",
    "claude-code",
    "codex",
    "gemini-cli",
    "cursor",
    "ai-coding",
    "skill-testing",
    "skill-linting",
    "developer-tools"
  ]
}
