{
  "name": "skillkit",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "skillkit",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@skillkit/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@skillkit/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@skillkit/linter": {
      "resolved": "packages/linter",
      "link": true
    },
    "node_modules/yaml": {
      "version": "2.8.2",
      "resolved": "https://registry.npmjs.org/yaml/-/yaml-2.8.2.tgz",
      "integrity": "sha512-mplynKqc1C2hTVYxd0PU2xQAc22TI1vShAYGksCCfxbn/dFwnHTNi1bvYsBTkhdUNtGIf5xNOg938rrSSYvS9A==",
      "license": "ISC",
      "bin": {
        "yaml": "bin.mjs"
      },
      "engines": {
        "node": ">= 14.6"
      },
      "funding": {
        "url": "https://github.com/sponsors/eemeli"
      }
    },
    "packages/cli": {
      "name": "@skillkit/cli",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@skillkit/core": "*",
        "@skillkit/linter": "*",
        "yaml": "^2.7.0"
      },
      "bin": {
        "skillkit": "src/index.ts"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/core": {
      "name": "@skillkit/core",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "yaml": "^2.7.0"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/linter": {
      "name": "@skillkit/linter",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@skillkit/core": "*"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
