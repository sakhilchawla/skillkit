{
  "name": "@skillkit/cli",
  "version": "0.1.0",
  "description": "CLI for building, testing, and linting Agent Skills",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "skillkit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skillkit/core": "*",
    "@skillkit/linter": "*",
    "@skillkit/test-harness": "*",
    "@skillkit/adapters": "*",
    "@skillkit/benchmarks": "*",
    "yaml": "^2.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
